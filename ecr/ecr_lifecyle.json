{
  "rules": [
    {
      "rulePriority": 1,
      "description": "Expire untagged images beyond the latest 3",
      "selection": {
        "tagStatus": "untagged",
        "countType": "imageCountMoreThan",
        "countNumber": 10
      },
      "action": {
        "type": "expire"
      }
    },
    {
      "rulePriority": 2,
      "description": "Retain ECS-protected images",
      "selection": {
        "tagStatus": "tagged",
        "tagPrefixList": ["ecs-"],
        "countType": "imageCountMoreThan",
        "countNumber": 9999
      },
      "action": {
        "type": "retain"
      }
    }
  ]
}
